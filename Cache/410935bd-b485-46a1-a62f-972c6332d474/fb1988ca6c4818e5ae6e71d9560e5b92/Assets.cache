    - toggledOffMaterial: !<reference.Material> 904939f3-edcc-4e7e-97fc-8ebba1acf43b
      toggledOffSelectMaterial: !<reference.Material> 3fd53954-3987-49d3-bb08-33942d93f6d2
      toggledOnMaterial: !<reference.Material> d4a4949d-7cd1-4b70-a0cf-4ed72c15cef7
