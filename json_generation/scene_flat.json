      "id": "backend_http_ws_api",
      "title": "HTTP and WebSocket API",
      "description": "Exposes /scribe-token for ElevenLabs realtime STT authorization and /ws for multiplexed transcript, text, audio, tool, widget, and done messages.",
      "shape": "cube",
      "pos": {
