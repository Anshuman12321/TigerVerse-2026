      "id": "backend_llm_pipeline",
      "title": "Gemini Reasoning and Tool Loop",
      "description": "Maintains conversation history, streams Gemini 2.5 Flash responses, executes manual function calls for up to five rounds, and feeds tool responses back into the model.",
      "shape": "cube",
      "pos": {
        "x": 0.0,
        "y": 0.0,
        "z": 10.0
      }
    },
    {
      "id": "backend_streaming_text_tts",
      "title": "Text Streaming and ElevenLabs TTS",
      "description": "Streams Gemini text chunks to the frontend, chunks complete sentences to ElevenLabs TTS over WebSocket, and forwards base64 audio chunks back to the client.",
      "shape": "cube",
      "pos": {
        "x": 0.0,
        "y": 5.0,
        "z": 5.0
      }
    },
    {
      "id": "backend_transcript_filter",
